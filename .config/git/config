[include]
    path = ~/.config/git/config.local

[color]
    ui = auto

[core]
    whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
    excludesfile = ~/.config/git/gitignore.global

#[merge]
#    tool = vimdiff

[color]
    ui = true

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red
    new = green
    whitespace = red reverse

[color "status"]
    #added = yellow
    #changed = green
    untracked = cyan
[alias]
    lg = log --graph --pretty='%C(yellow)%h %C(cyan)%cd %Cblue%aN%C(auto)%d %Creset%s' --date=human --branches
    ltg = log --no-walk --tags --decorate=full --oneline
[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
[commit]
    template = ~/.config/git/gitmessage.txt
[pull]
    rebase = true
[diff]
    tool = nvimdiff_auto
[difftool]
    prompt = false
[difftool "nvimdiff_auto"]
    cmd = "_e=vim; command -v nvim >/dev/null 2>&1 && _e=nvim; \"$_e\" -d \"$LOCAL\" \"$REMOTE\""
[merge]
    tool = nvimdiff_auto
[mergetool]
    prompt = false
    keepBackup = false
[mergetool "nvimdiff_auto"]
    cmd = "_e=vim; command -v nvim >/dev/null 2>&1 && _e=nvim; \"$_e\" -d \"$LOCAL\" \"$BASE\" \"$REMOTE\" \"$MERGED\" -c \"4wincmd w\" -c \"wincmd J\""
